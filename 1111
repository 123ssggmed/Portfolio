"""
Financial Ratio Calculator.

Calculate standard financial ratios from XBRL data.

from typing import Dict, Optional, List
from dataclasses import dataclass
from enum import Enum
import logging

logger = logging.getLogger(__name__)

class RatioCategory(Enum):
    PROFITABILITY = 'profitability'
    ASSET_QUALITY = 'asset_quality'
    CAPITAL = 'capital'
    LIQUIDITY = 'liquidity'
    EFFICIENCY = 'efficiency'

@dataclass
class RatioResult:
    '''
    Result of a ratio calculation.
    '''
    name: str
    code: str
    category: RatioCategory
    value: Optional[float]
    numerator: Optional[float]
    denominator: Optional[float]
    formula: str
    interpretation: str
    benchmark_min: Optional[float] = None
    benchmark_max: Optional[float] = None
    
    @property
    def is_calculated(self) -> bool:
        return self.value is not None
    
    @property
    def formatted_value(self) -> str:
        if self.value is None:
            return 'N/A'
        if abs(self.value) < 1:
            return f"{self.value:.2%}"
        return f"{self.value:.2f}"
    
    @property
    def status(self) -> str:
        '''Compare to benchmark if available.'''
        if self.value is None:
            return 'unknown'
        if self.benchmark_min and self.value < self.benchmark_min:
            return 'below_benchmark'
        if self.benchmark_max and self.value > self.benchmark_max:
            return 'above_benchmark'
        return 'within_benchmark'

class RatioCalculator:
    '''
    Calculator for financial ratios.
    
    Supports:
    - Standard bank/financial institution ratios
    - Custom ratio definitions
    - Benchmark comparisons
    - Multi-period calculations
    '''
    
    def __init__(self, ratio_config: Dict = None, 
                 concept_mapping: Dict = None):
        '''
        Initialize calculator.
        
        Args:
            ratio_config: Configuration for ratio calculations
            concept_mapping: Mapping from standard names to XBRL concepts
        '''
        self.ratio_config = ratio_config or self._default_ratio_config()
        self.concept_mapping = concept_mapping or self._default_concept_mapping()
    
    def calculate_all(self, financial_data: Dict[str, float]) -> Dict[str, RatioResult]:
        '''
        Calculate all configured ratios.
        
        Args:
            financial_data: Dictionary of concept -> value
            
        Returns:
            Dictionary of ratio_code -> RatioResult
        '''
        results = {}
        
        for ratio_code, config in self.ratio_config.items():
            result = self._calculate_ratio(ratio_code, config, financial_data)
            results[ratio_code] = result
            
        return results
    
    def calculate_ratio(self, ratio_code: str, 
                       financial_data: Dict[str, float]) -> RatioResult:
        '''Calculate a single ratio.'''
        if ratio_code not in self.ratio_config:
            raise ValueError(f"Unknown ratio: {ratio_code}")
            
        config = self.ratio_config[ratio_code]
        return self._calculate_ratio(ratio_code, config, financial_data)
    
    def _calculate_ratio(self, ratio_code: str, config: Dict,
                        financial_data: Dict[str, float]) -> RatioResult:
        '''Internal ratio calculation.'''
        
        # Get numerator
        numerator = self._evaluate_expression(
            config['numerator'], financial_data
        )
        
        # Get denominator
        denominator = self._evaluate_expression(
            config['denominator'], financial_data
        )
        
        # Calculate ratio
        value = None
        if numerator is not None and denominator is not None and denominator != 0:
            value = numerator / denominator
            
            # Apply multiplier if specified (e.g., for percentages)
            if 'multiplier' in config:
                value *= config['multiplier']
        
        return RatioResult(
            name=config['name'],
            code=ratio_code,
            category=RatioCategory(config['category']),
            value=value,
            numerator=numerator,
            denominator=denominator,
            formula=config['formula'],
            interpretation=config.get('interpretation', ''),
            benchmark_min=config.get('benchmark_min'),
            benchmark_max=config.get('benchmark_max')
        )
    
    def _evaluate_expression(self, expression: str, 
                            data: Dict[str, float]) -> Optional[float]:
        '''
        Evaluate a mathematical expression with variable substitution.
        
        Expression can include:
        - Variable names (mapped concepts)
        - Operators: +, -, *, /
        - Parentheses
        
        Example: "(Loans + Investments) / TotalAssets"
        '''
        if not expression:
            return None
            
        # Map variable names to XBRL concepts and get values
        try:
            # Replace variable names with values
            expr = expression
            for var_name, concept in self.concept_mapping.items():
                if var_name in expr:
                    value = data.get(concept, data.get(var_name, 0))
                    expr = expr.replace(var_name, str(value))
            
            # Evaluate (safely)
            result = eval(expr, {"__builtins__": {}}, {})
            return float(result)
        except Exception as e:
            logger.warning(f"Error evaluating expression '{expression}': {e}")
            return None
    
