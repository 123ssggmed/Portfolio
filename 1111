"""
XBRL Document Parser.

Parse XBRL instance documents and extract financial facts.

from lxml import etree
from typing import Dict, List, Optional, Tuple
from dataclasses import dataclass
from datetime import date
import logging

logger = logging.getLogger(__name__)

@dataclass
class XBRLFact:
    '''
    Represents a single XBRL fact (data point).
    
    Attributes:
        concept: The XBRL concept/element name
        value: The reported value
        unit: Unit of measurement (e.g., COP, USD, shares)
        context_ref: Reference to context element
        decimals: Precision indicator
        period_start: Period start date (for duration)
        period_end: Period end date
        instant: Instant date (for point-in-time)
        dimensions: Dimensional qualifiers
    '''
    concept: str
    value: any
    unit: Optional[str]
    context_ref: str
    decimals: Optional[int]
    period_start: Optional[date]
    period_end: Optional[date]
    instant: Optional[date]
    dimensions: Dict[str, str]
    
    @property
    def numeric_value(self) -> Optional[float]:
        '''Return value as float if numeric.'''
        try:
            return float(self.value)
        except (ValueError, TypeError):
            return None
    
    @property
    def period_key(self) -> str:
        '''Generate period key for grouping.'''
        if self.instant:
            return f"instant:{self.instant.isoformat()}"
        elif self.period_end:
            return f"duration:{self.period_start.isoformat()}:{self.period_end.isoformat()}"
        return "unknown"

@dataclass
class XBRLContext:
    '''
    Represents an XBRL context (reporting context).
    '''
    id: str
    entity: str
    period_type: str  # 'instant' or 'duration'
    instant: Optional[date]
    start_date: Optional[date]
    end_date: Optional[date]
    dimensions: Dict[str, str]

class XBRLParser:
    '''
    Parser for XBRL instance documents.
    
    Handles:
    - XBRL 2.1 instance documents
    - Inline XBRL (iXBRL)
    - Multiple namespaces
    - Dimensional data
    '''
    
    # Common XBRL namespaces
    NAMESPACES = {
        'xbrli': 'http://www.xbrl.org/2003/instance',
        'link': 'http://www.xbrl.org/2003/linkbase',
        'xlink': 'http://www.w3.org/1999/xlink',
        'iso4217': 'http://www.xbrl.org/2003/iso4217',
        'xbrldi': 'http://xbrl.org/2006/xbrldi',
        'xbrldt': 'http://xbrl.org/2005/xbrldt'
    }
    
    def __init__(self, taxonomy_mapping: Dict = None):
        '''
        Initialize parser.
        
        Args:
            taxonomy_mapping: Optional mapping of taxonomy elements to standard names
        '''
        self.taxonomy_mapping = taxonomy_mapping or {}
        self.contexts: Dict[str, XBRLContext] = {}
        self.units: Dict[str, str] = {}
        self.facts: List[XBRLFact] = []
        
    def parse(self, file_path: str) -> 'XBRLDocument':
        '''
        Parse XBRL file and return structured document.
        
        Args:
            file_path: Path to XBRL instance document
            
        Returns:
            XBRLDocument with parsed data
        '''
        logger.info(f"Parsing XBRL file: {file_path}")
        
        tree = etree.parse(file_path)
        root = tree.getroot()
        
        # Detect namespaces used in document
        self._detect_namespaces(root)
        
        # Parse contexts
        self._parse_contexts(root)
        logger.debug(f"Parsed {len(self.contexts)} contexts")
        
        # Parse units
        self._parse_units(root)
        logger.debug(f"Parsed {len(self.units)} units")
        
        # Parse facts
        self._parse_facts(root)
        logger.info(f"Parsed {len(self.facts)} facts")
        
        return XBRLDocument(
            file_path=file_path,
            contexts=self.contexts,
            units=self.units,
            facts=self.facts
        )
    
    def _detect_namespaces(self, root: etree.Element):
        '''Detect and register namespaces from document.'''
        for prefix, uri in root.nsmap.items():
            if prefix:
                self.NAMESPACES[prefix] = uri
                
    def _parse_contexts(self, root: etree.Element):
        '''Parse all context elements.'''
        for ctx_elem in root.findall('.//xbrli:context', self.NAMESPACES):
            ctx_id = ctx_elem.get('id')
            
            # Parse entity
            entity_elem = ctx_elem.find('xbrli:entity', self.NAMESPACES)
            entity = entity_elem.find('xbrli:identifier', self.NAMESPACES).text
            
            # Parse period
            period_elem = ctx_elem.find('xbrli:period', self.NAMESPACES)
            instant = None
            start_date = None
            end_date = None
            
            instant_elem = period_elem.find('xbrli:instant', self.NAMESPACES)
            if instant_elem is not None:
                instant = self._parse_date(instant_elem.text)
                period_type = 'instant'
            else:
                start_elem = period_elem.find('xbrli:startDate', self.NAMESPACES)
                end_elem = period_elem.find('xbrli:endDate', self.NAMESPACES)
                start_date = self._parse_date(start_elem.text)
                end_date = self._parse_date(end_elem.text)
                period_type = 'duration'
            
            # Parse dimensions (if any)
            dimensions = self._parse_dimensions(ctx_elem)
            
            self.contexts[ctx_id] = XBRLContext(
                id=ctx_id,
                entity=entity,
                period_type=period_type,
                instant=instant,
                start_date=start_date,
                end_date=end_date,
                dimensions=dimensions
            )
    
    def _parse_units(self, root: etree.Element):
        '''Parse all unit elements.'''
        for unit_elem in root.findall('.//xbrli:unit', self.NAMESPACES):
            unit_id = unit_elem.get('id')
            
            # Simple unit (single measure)
            measure = unit_elem.find('xbrli:measure', self.NAMESPACES)
            if measure is not None:
                # Extract unit code (e.g., 'iso4217:COP' -> 'COP')
                unit_value = measure.text.split(':')[-1] if ':' in measure.text else measure.text
                self.units[unit_id] = unit_value
            else:
                # Compound unit (divide)
                self.units[unit_id] = 'compound'
    
    def _parse_facts(self, root: etree.Element):
        '''Parse all fact elements.'''
        # Facts are elements that reference a context
        for elem in root.iter():
            context_ref = elem.get('contextRef')
            if context_ref and context_ref in self.contexts:
                fact = self._parse_fact_element(elem)
                if fact:
                    self.facts.append(fact)
    
    def _parse_fact_element(self, elem: etree.Element) -> Optional[XBRLFact]:
        '''Parse a single fact element.'''
        # Get concept name (local name of element)
        concept = etree.QName(elem).localname
        
        # Get value
        value = elem.text
        if value:
            value = value.strip()
            
        # Skip if no value
        if not value:
            return None
            
        # Get context
        context_ref = elem.get('contextRef')
        context = self.contexts.get(context_ref)
        
        # Get unit
        unit_ref = elem.get('unitRef')
        unit = self.units.get(unit_ref) if unit_ref else None
        
        # Get decimals
        decimals_str = elem.get('decimals')
        decimals = int(decimals_str) if decimals_str and decimals_str != 'INF' else None
        
        return XBRLFact(
            concept=concept,
            value=value,
            unit=unit,
            context_ref=context_ref,
            decimals=decimals,
            period_start=context.start_date if context else None,
            period_end=context.end_date if context else None,
            instant=context.instant if context else None,
            dimensions=context.dimensions if context else {}
        )
    
    def _parse_dimensions(self, ctx_elem: etree.Element) -> Dict[str, str]:
        '''Parse dimensional information from context.'''
        dimensions = {}
        
        # Look for explicit dimensions
        for dim_elem in ctx_elem.findall('.//xbrldi:explicitMember', self.NAMESPACES):
            dimension = dim_elem.get('dimension')
            member = dim_elem.text
            if dimension and member:
                dim_name = dimension.split(':')[-1]
                dimensions[dim_name] = member
                
        return dimensions
    
    def _parse_date(self, date_str: str) -> date:
        '''Parse date string to date object.'''
        return date.fromisoformat(date_str)


@dataclass
class XBRLDocument:
    '''
    Represents a parsed XBRL document.
    '''
    file_path: str
    contexts: Dict[str, XBRLContext]
    units: Dict[str, str]
    facts: List[XBRLFact]
    
    def get_fact(self, concept: str, period: str = None, 
                 dimensions: Dict = None) -> Optional[XBRLFact]:
        '''
        Get a specific fact by concept and optional filters.
        '''
        for fact in self.facts:
            if fact.concept == concept:
                if period and fact.period_key != period:
                    continue
                if dimensions:
                    if not all(fact.dimensions.get(k) == v for k, v in dimensions.items()):
                        continue
                return fact
        return None
    
    def get_facts_by_concept(self, concept: str) -> List[XBRLFact]:
        '''Get all facts for a concept.'''
