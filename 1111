    id: str
    engagement: str
    title: str
    description: str
    due_date: Optional[datetime]
    source_file: str = ''
    import_date: datetime = field(default_factory=datetime.now)
    assigned_area: Optional[str] = None
    confidence_score: float = 0.0
    status: Status = Status.NEW
    priority: Priority = Priority.MEDIUM
    matched_keywords: List[str] = field(default_factory=list)
    notes: str = ''
    
    def __post_init__(self):
        '''Calculate priority based on due date.'''
        if self.due_date:
            days_until_due = (self.due_date - datetime.now()).days
            if days_until_due < 0:
                self.status = Status.OVERDUE
                self.priority = Priority.URGENT
            elif days_until_due <= 3:
                self.priority = Priority.URGENT
            elif days_until_due <= 7:
                self.priority = Priority.HIGH
            elif days_until_due <= 14:
                self.priority = Priority.MEDIUM
            else:
                self.priority = Priority.LOW
    
    @property
    def days_until_due(self) -> int:
        '''Calculate days until deadline.'''
        if not self.due_date:
            return 999
        return (self.due_date - datetime.now()).days
    
    @property
    def is_overdue(self) -> bool:
        '''Check if requirement is past due.'''
        return self.days_until_due < 0
    
    def to_dict(self) -> dict:
        '''Convert to dictionary for serialization.'''
        return {
            'id': self.id,
            'engagement': self.engagement,
            'title': self.title,
            'description': self.description,
            'due_date': self.due_date.isoformat() if self.due_date else None,
            'assigned_area': self.assigned_area,
            'confidence_score': self.confidence_score,
            'status': self.status.value,
            'priority': self.priority.value,
            'matched_keywords': self.matched_keywords
        }
    
    @classmethod
    def from_dict(cls, data: dict) -> 'Requirement':
        '''Create instance from dictionary.'''
        if data.get('due_date'):
            data['due_date'] = datetime.fromisoformat(data['due_date'])
        data['status'] = Status(data.get('status', 'new'))
        data['priority'] = Priority(data.get('priority', 2))
        return cls(**data)


@dataclass
class RequirementBatch:
    '''
    Collection of requirements from a single import.
    '''
    
    requirements: List[Requirement]
    source_file: str
    engagement: str
    import_date: datetime = field(default_factory=datetime.now)
    
    def __len__(self) -> int:
        return len(self.requirements)
    
    def by_area(self) -> dict:
        '''Group requirements by assigned area.'''
        grouped = {}
        for req in self.requirements:
            area = req.assigned_area or 'UNASSIGNED'
            if area not in grouped:
                grouped[area] = []
            grouped[area].append(req)
        return grouped
    
    def by_due_date(self) -> dict:
        '''Group requirements by due date.'''
        grouped = {}
        for req in self.requirements:
            date_key = req.due_date.strftime('%Y-%m-%d') if req.due_date else 'NO_DATE'
            if date_key not in grouped:
                grouped[date_key] = []
            grouped[date_key].append(req)
        return dict(sorted(grouped.items()))
    
    def overdue(self) -> List[Requirement]:
        '''Get overdue requirements.'''
        return [r for r in self.requirements if r.is_overdue]
    
    def unassigned(self) -> List[Requirement]:
        '''Get unassigned requirements.'''
        return [r for r in self.requirements if not r.assigned_area]
    
    def statistics(self) -> dict:
        '''Generate batch statistics.'''
