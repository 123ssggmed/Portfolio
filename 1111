    WHEN [Days Past Due] <= 30 THEN '1-30'
    WHEN [Days Past Due] <= 60 THEN '31-60'
    WHEN [Days Past Due] <= 90 THEN '61-90'
    ELSE '90+'
END

// Prior Month DPD Bucket
LOOKUP([DPD Bucket], -1)

// Roll Rate (Dynamic)
// Parameter: [Starting Bucket], [Ending Bucket]
COUNTD(IF [DPD Bucket Prior] = [Starting Bucket Parameter] 
       AND [DPD Bucket Current] = [Ending Bucket Parameter]
       THEN [Loan ID] END)
/ COUNTD(IF [DPD Bucket Prior] = [Starting Bucket Parameter] THEN [Loan ID] END)

// Cure Rate (30+ back to Current)
COUNTD(IF [DPD Bucket Prior] != '0-Current' AND [DPD Bucket Current] = '0-Current'
       THEN [Loan ID] END)
/ COUNTD(IF [DPD Bucket Prior] != '0-Current' THEN [Loan ID] END)

// ============ CONCENTRATION ============

// Customer Exposure % of Portfolio
SUM([Current Balance]) / TOTAL(SUM([Current Balance]))

// HHI Index (Herfindahl-Hirschman)
SUM(POWER([Customer Exposure %], 2))

// Sector Concentration
{ FIXED [Economic Sector] : SUM([Current Balance]) }
/ TOTAL(SUM([Current Balance]))

// Top N Flag
RANK([Customer Exposure], 'desc') <= [Top N Parameter]

