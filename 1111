CREATE TABLE int_regulatory.int_loan_classification AS
WITH loan_with_rating AS (
    SELECT
        l.loan_id,
        l.customer_id,
        l.current_balance,
        l.days_past_due,
        l.collateral_type,
        l.collateral_value,
        -- Classification logic per SFC Circular Externa
        CASE
            WHEN l.days_past_due = 0 THEN 'A'
            WHEN l.days_past_due BETWEEN 1 AND 30 THEN 'B'
            WHEN l.days_past_due BETWEEN 31 AND 60 THEN 'C'
            WHEN l.days_past_due BETWEEN 61 AND 90 THEN 'D'
            ELSE 'E'
        END AS rating_calculated,
        l.rating_code AS rating_reported
    FROM stg_regulatory.stg_loans l
),
provision_rates AS (
    SELECT
        *,
        CASE rating_calculated
            WHEN 'A' THEN 0.01
            WHEN 'B' THEN 0.032
            WHEN 'C' THEN 0.10
            WHEN 'D' THEN 0.50
            WHEN 'E' THEN 1.00
        END AS provision_rate_unsecured,
        CASE 
            WHEN collateral_type = 'ADMISIBLE' THEN 0.5
            ELSE 1.0
        END AS collateral_factor
    FROM loan_with_rating
)
SELECT
    *,
    current_balance * provision_rate_unsecured * collateral_factor AS provision_required
FROM provision_rates;
