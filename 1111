"""
Intelligent requirement classification engine.

from typing import List, Dict, Tuple, Optional
import re
from collections import defaultdict
import logging

from ..core.requirement import Requirement

logger = logging.getLogger(__name__)

class RequirementClassifier:
    '''
    Classifies audit requirements to responsible areas.
    
    Uses multi-strategy approach:
    1. Exact keyword matching
    2. Fuzzy/partial matching
    3. Weighted scoring
    4. Context analysis
    '''
    
    def __init__(self, rules: Dict[str, Dict]):
        '''
        Initialize with classification rules.
        
        Args:
            rules: Dictionary with structure:
                {
                    'AREA_CODE': {
                        'name': 'Full Area Name',
                        'keywords': ['keyword1', 'keyword2', ...],
                        'weights': {'keyword1': 2.0, 'keyword2': 1.5},
                        'exclusions': ['not_this_keyword'],
                        'patterns': [r'regex_pattern']
                    }
                }
        '''
        self.rules = rules
        self._compile_patterns()
        
    def _compile_patterns(self):
        '''Pre-compile regex patterns for efficiency.'''
        for area, config in self.rules.items():
            if 'patterns' in config:
                config['compiled_patterns'] = [
                    re.compile(p, re.IGNORECASE) 
                    for p in config['patterns']
                ]
    
    def classify(self, requirement: Requirement) -> Tuple[str, float, List[str]]:
        '''
        Classify a single requirement.
        
        Args:
            requirement: Requirement to classify
            
        Returns:
            Tuple of (area_code, confidence_score, matched_keywords)
        '''
        text = self._prepare_text(requirement)
        
        scores = {}
        matches = defaultdict(list)
        
        for area, config in self.rules.items():
            score, area_matches = self._calculate_area_score(text, config)
            
            # Apply exclusions
            if 'exclusions' in config:
                for excl in config['exclusions']:
                    if excl.lower() in text:
                        score *= 0.1  # Heavy penalty
                        
            scores[area] = score
            matches[area] = area_matches
        
        # Find best match
        if not scores or max(scores.values()) == 0:
            return (None, 0.0, [])
            
        best_area = max(scores, key=scores.get)
        best_score = scores[best_area]
        
        # Normalize confidence to 0-1 scale
        confidence = min(best_score / 10.0, 1.0)
        
        # Check if clearly best (not ambiguous)
        sorted_scores = sorted(scores.values(), reverse=True)
        if len(sorted_scores) > 1 and sorted_scores[0] > 0:
            # Reduce confidence if second best is close
            ratio = sorted_scores[1] / sorted_scores[0] if sorted_scores[0] > 0 else 0
            if ratio > 0.8:
                confidence *= 0.7  # Ambiguous match
                
        return (best_area, confidence, matches[best_area])
    
    def classify_batch(self, requirements: List[Requirement]) -> List[Requirement]:
        '''
        Classify multiple requirements.
        
        Modifies requirements in place and returns them.
        '''
        for req in requirements:
            area, confidence, keywords = self.classify(req)
            req.assigned_area = area
            req.confidence_score = confidence
            req.matched_keywords = keywords
            
        return requirements
    
    def _prepare_text(self, requirement: Requirement) -> str:
        '''Prepare text for classification.'''
        # Combine title and description
        text = f"{requirement.title} {requirement.description}"
        
        # Normalize
        text = text.lower()
        text = self._normalize_spanish(text)
        
        return text
    
    def _normalize_spanish(self, text: str) -> str:
        '''Normalize Spanish text (remove accents, etc.).'''
        replacements = {
            'á': 'a', 'é': 'e', 'í': 'i', 'ó': 'o', 'ú': 'u',
            'ü': 'u', 'ñ': 'n'
        }
        for old, new in replacements.items():
            text = text.replace(old, new)
        return text
    
    def _calculate_area_score(self, text: str, 
                              config: Dict) -> Tuple[float, List[str]]:
        '''Calculate score for a single area.'''
        score = 0.0
        matched = []
        
        keywords = config.get('keywords', [])
        weights = config.get('weights', {})
        
        for keyword in keywords:
            keyword_lower = keyword.lower()
            keyword_normalized = self._normalize_spanish(keyword_lower)
            
            if keyword_normalized in text:
                weight = weights.get(keyword, 1.0)
                score += weight
                matched.append(keyword)
                
                # Bonus for exact phrase match
                if f" {keyword_normalized} " in f" {text} ":
                    score += weight * 0.5
        
        # Check regex patterns
        if 'compiled_patterns' in config:
            for pattern in config['compiled_patterns']:
                if pattern.search(text):
                    score += 2.0
                    matched.append(f"pattern:{pattern.pattern}")
        
        return (score, matched)
    
    def explain_classification(self, requirement: Requirement) -> str:
        '''
        Generate human-readable explanation of classification.
        '''
        area, confidence, keywords = self.classify(requirement)
        
        explanation = []
        explanation.append(f"Requirement: {requirement.id} - {requirement.title[:50]}...")
        explanation.append(f"Assigned to: {area or 'UNASSIGNED'}")
        explanation.append(f"Confidence: {confidence:.1%}")
        
        if keywords:
            explanation.append(f"Matched keywords: {', '.join(keywords)}")
        
        # Show alternative matches
        text = self._prepare_text(requirement)
        all_scores = {}
        for a, config in self.rules.items():
            score, _ = self._calculate_area_score(text, config)
            all_scores[a] = score
            
        top_3 = sorted(all_scores.items(), key=lambda x: x[1], reverse=True)[:3]
        explanation.append("Top matches:")
        for a, s in top_3:
            explanation.append(f"  - {a}: {s:.2f}")
        
        return "\n".join(explanation)


