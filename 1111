"""
Email draft generator.

from typing import List, Dict, Optional
from datetime import datetime
from pathlib import Path
import logging
from jinja2 import Environment, FileSystemLoader, select_autoescape

from ..core.requirement import Requirement, RequirementBatch

logger = logging.getLogger(__name__)

class EmailGenerator:
    '''
    Generates professional email drafts for audit requirement distribution.
    
    Features:
    - Multiple output formats (HTML, plain text, Outlook-ready)
    - Template customization
    - Grouping by area, date, or custom criteria
    - Spanish business language
    '''
    
    def __init__(self, templates_dir: str = None):
        '''
        Initialize generator with templates directory.
        '''
        if templates_dir:
            self.env = Environment(
                loader=FileSystemLoader(templates_dir),
                autoescape=select_autoescape(['html', 'xml'])
            )
        else:
            self.env = None
            
        self.default_sender = {
            'name': 'Santiago Buitrago',
            'title': 'Practicante Jurídico',
            'department': 'Gerencia Jurídica',
            'company': 'IRIS Compañía de Financiamiento S.A.'
        }
    
    def generate_by_area(self, batch: RequirementBatch, 
                         personnel_lookup: callable) -> List[Dict]:
        '''
        Generate one email per assigned area.
        
        Args:
            batch: RequirementBatch with classified requirements
            personnel_lookup: Function to lookup area contacts
            
        Returns:
            List of email dictionaries with keys:
            - area, recipients, cc, subject, body_html, body_text, requirements
        '''
        emails = []
        
        for area, requirements in batch.by_area().items():
            if area == 'UNASSIGNED':
                continue
                
            # Lookup recipients
            recipients = personnel_lookup(area, level='manager')
            cc = personnel_lookup(area, level='coordinator')
            
            # Generate email
            email = self._generate_email(
                area=area,
                requirements=requirements,
                engagement=batch.engagement,
                recipients=recipients,
                cc=cc
            )
            
            emails.append(email)
            
        return emails
    
    def generate_by_date(self, batch: RequirementBatch,
                         personnel_lookup: callable) -> List[Dict]:
        '''
        Generate emails grouped by due date.
        '''
        emails = []
        
        for date_str, requirements in batch.by_due_date().items():
            # Aggregate areas involved
            areas = set(r.assigned_area for r in requirements if r.assigned_area)
            
            # Get all recipients
            recipients = []
            cc = []
            for area in areas:
                recipients.extend(personnel_lookup(area, level='manager'))
                cc.extend(personnel_lookup(area, level='coordinator'))
            
            email = self._generate_email(
                area=f"Múltiples áreas (Venc. {date_str})",
                requirements=requirements,
                engagement=batch.engagement,
                recipients=list(set(recipients)),
                cc=list(set(cc)),
                group_by='date'
            )
            
            emails.append(email)
            
        return emails
    
    def _generate_email(self, area: str, requirements: List[Requirement],
                        engagement: str, recipients: List[Dict],
                        cc: List[Dict], group_by: str = 'area') -> Dict:
        '''
        Generate a single email.
        '''
        # Format dates for display
        dates = set(r.due_date.strftime('%d de %B de %Y') 
                   if r.due_date else 'Sin fecha'
                   for r in requirements)
        
        # Determine due date text
        if len(dates) == 1:
            due_date_text = list(dates)[0]
        else:
            due_date_text = "fechas indicadas en cada requerimiento"
        
        # Generate subject
        subject = self._generate_subject(engagement, area, requirements)
        
        # Generate body
        body_html = self._generate_html_body(
            requirements=requirements,
            engagement=engagement,
            area=area,
            due_date_text=due_date_text
        )
        
        body_text = self._generate_text_body(
            requirements=requirements,
            engagement=engagement,
            area=area,
            due_date_text=due_date_text
        )
        
        # Format recipient strings
        to_str = "; ".join(f"{r['name']}" for r in recipients)
        cc_str = "; ".join(f"{r['name']}" for r in cc)
        
        return {
            'area': area,
            'engagement': engagement,
            'recipients': recipients,
            'recipients_str': to_str,
            'cc': cc,
            'cc_str': cc_str,
            'subject': subject,
            'body_html': body_html,
