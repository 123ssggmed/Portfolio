"""
Excel file reader for audit requirements.

import pandas as pd
from pathlib import Path
from typing import List, Optional, Tuple
from datetime import datetime
import logging

from ..core.requirement import Requirement, RequirementBatch

logger = logging.getLogger(__name__)

class ExcelReader:
    '''
    Reads audit requirements from Excel files.
    
    Handles:
    - Multiple Excel formats (.xlsx, .xls)
    - Various encodings (UTF-8, Latin-1, CP1252)
    - Header detection
    - Column mapping
    - Data validation
    '''
    
    # Standard column mappings (source -> internal)
    DEFAULT_COLUMN_MAP = {
        'id': ['ID', 'Id', 'Req ID', 'Requirement ID', 'Número', 'No.', '#'],
        'engagement': ['Trabajo', 'Engagement', 'Proyecto', 'Auditoría'],
        'title': ['Requerimiento', 'Título', 'Title', 'Nombre', 'Requirement'],
        'description': ['Descripción', 'Description', 'Detalle', 'Detail'],
        'due_date': ['Fecha de Vencimiento', 'Due Date', 'Vencimiento', 'Fecha Límite', 'Deadline']
    }
    
    def __init__(self, column_map: dict = None):
        '''
        Initialize reader with optional custom column mapping.
        
        Args:
            column_map: Dictionary mapping internal names to possible source column names
        '''
        self.column_map = column_map or self.DEFAULT_COLUMN_MAP
        
    def read(self, file_path: str, sheet_name: str = None, 
             skip_rows: int = 0) -> RequirementBatch:
        '''
        Read requirements from Excel file.
        
        Args:
            file_path: Path to Excel file
            sheet_name: Specific sheet to read (default: first sheet)
            skip_rows: Number of rows to skip before header
            
        Returns:
            RequirementBatch with parsed requirements
            
        Raises:
            FileNotFoundError: If file doesn't exist
            ValueError: If required columns not found
        '''
        path = Path(file_path)
        if not path.exists():
            raise FileNotFoundError(f"File not found: {file_path}")
            
        logger.info(f"Reading file: {file_path}")
        
        # Try different read strategies
        df = self._read_with_detection(path, sheet_name, skip_rows)
        
        # Map columns to internal names
        df = self._map_columns(df)
        
        # Validate required columns
        self._validate_columns(df)
        
        # Parse into requirements
        requirements = self._parse_requirements(df, path.name)
        
        # Detect engagement name
        engagement = self._detect_engagement(df, requirements)
        
        logger.info(f"Parsed {len(requirements)} requirements from {path.name}")
        
        return RequirementBatch(
            requirements=requirements,
            source_file=str(path),
            engagement=engagement
        )
    
    def _read_with_detection(self, path: Path, sheet_name: str, 
                             skip_rows: int) -> pd.DataFrame:
        '''
        Read Excel with automatic header detection.
        
        Tries multiple strategies:
        1. Standard read
        2. Skip rows to find header
        3. Detect header by content
        '''
        # First try: standard read
        try:
            df = pd.read_excel(path, sheet_name=sheet_name or 0, 
                              skiprows=skip_rows)
            if self._has_valid_header(df):
                return df
        except Exception as e:
            logger.debug(f"Standard read failed: {e}")
        
        # Second try: detect header row
        for skip in range(10):
            try:
                df = pd.read_excel(path, sheet_name=sheet_name or 0, 
                                  skiprows=skip, header=0)
                if self._has_valid_header(df):
                    logger.info(f"Detected header at row {skip}")
                    return df
            except:
                continue
        
        raise ValueError(f"Could not detect valid header in {path}")
    
    def _has_valid_header(self, df: pd.DataFrame) -> bool:
        '''Check if DataFrame has recognizable header columns.'''
        columns_lower = [str(c).lower() for c in df.columns]
        
        # Must have at least ID and description columns
        has_id = any(
            any(variant.lower() in col for variant in self.column_map['id'])
            for col in columns_lower
        )
        has_desc = any(
            any(variant.lower() in col for variant in self.column_map['description'])
            for col in columns_lower
        )
        
        return has_id or has_desc
    
    def _map_columns(self, df: pd.DataFrame) -> pd.DataFrame:
        '''Map source columns to internal names.'''
        column_mapping = {}
        
        for internal_name, variants in self.column_map.items():
            for variant in variants:
                for col in df.columns:
                    if variant.lower() in str(col).lower():
                        column_mapping[col] = internal_name
                        break
                if internal_name in column_mapping.values():
                    break
        
        return df.rename(columns=column_mapping)
    
    def _validate_columns(self, df: pd.DataFrame):
        '''Validate that required columns exist.'''
        required = ['description']  # Minimum required
        missing = [col for col in required if col not in df.columns]
        
        if missing:
            raise ValueError(f"Missing required columns: {missing}")
    
    def _parse_requirements(self, df: pd.DataFrame, 
                           source_file: str) -> List[Requirement]:
        '''Parse DataFrame rows into Requirement objects.'''
        requirements = []
        
        for idx, row in df.iterrows():
            try:
                req = Requirement(
                    id=str(row.get('id', idx + 1)),
                    engagement=str(row.get('engagement', '')),
                    title=str(row.get('title', row.get('description', '')[:100])),
                    description=str(row.get('description', '')),
                    due_date=self._parse_date(row.get('due_date')),
                    source_file=source_file
                )
                requirements.append(req)
            except Exception as e:
                logger.warning(f"Error parsing row {idx}: {e}")
                
        return requirements
    
    def _parse_date(self, value) -> Optional[datetime]:
        '''Parse various date formats.'''
        if pd.isna(value):
            return None
            
        if isinstance(value, datetime):
            return value
            
        if isinstance(value, pd.Timestamp):
            return value.to_pydatetime()
            
        # Try string parsing
        date_formats = [
            '%Y-%m-%d',
            '%d/%m/%Y',
            '%d-%m-%Y',
            '%d de %B de %Y',  # Spanish format
        ]
        
        for fmt in date_formats:
            try:
                return datetime.strptime(str(value), fmt)
            except:
                continue
                
        logger.warning(f"Could not parse date: {value}")
        return None
    
    def _detect_engagement(self, df: pd.DataFrame, 
                          requirements: List[Requirement]) -> str:
        '''Detect engagement name from data.'''
        # Check if engagement column has consistent value
        if 'engagement' in df.columns:
            unique_engagements = df['engagement'].dropna().unique()
            if len(unique_engagements) == 1:
                return str(unique_engagements[0])
        
        # Check requirements
        engagements = [r.engagement for r in requirements if r.engagement]
        if engagements:
            from collections import Counter
            return Counter(engagements).most_common(1)[0][0]
        
        return 'Unknown Engagement'
