from .email.generator import EmailGenerator

console = Console()

@click.group()
@click.option('--verbose', '-v', is_flag=True, help='Enable verbose output')
@click.pass_context
def cli(ctx, verbose):
    '''
    Audit-NEXUS: Audit Requirements Processing System
    
    Process and distribute audit requirements automatically.
    '''
    ctx.ensure_object(dict)
    ctx.obj['verbose'] = verbose
    
    # Setup logging
    level = logging.DEBUG if verbose else logging.INFO
    logging.basicConfig(level=level, format='%(asctime)s - %(levelname)s - %(message)s')

@cli.command()
@click.argument('input_file', type=click.Path(exists=True))
@click.option('--personnel', '-p', type=click.Path(exists=True), 
              help='Personnel database CSV file')
@click.option('--output', '-o', type=click.Path(), default='./output',
              help='Output directory')
@click.option('--format', '-f', type=click.Choice(['html', 'txt', 'both']), 
              default='both', help='Output format')
@click.option('--group-by', '-g', type=click.Choice(['area', 'date']), 
              default='area', help='How to group requirements')
@click.pass_context
def process(ctx, input_file, personnel, output, format, group_by):
    '''
    Process audit requirements file and generate email drafts.
    
    INPUT_FILE: Excel/CSV file containing audit requirements
    '''
    console.print(f"[bold blue]Processing: {input_file}[/bold blue]")
    
    with Progress() as progress:
        task = progress.add_task("[cyan]Processing...", total=100)
        
        # Step 1: Read input file
        progress.update(task, advance=10, description="[cyan]Reading file...")
        reader = ExcelReader()
        batch = reader.read(input_file)
        console.print(f"  ✓ Loaded {len(batch)} requirements")
        
        # Step 2: Classify requirements
        progress.update(task, advance=30, description="[cyan]Classifying...")
        classifier = RequirementClassifier(DEFAULT_RULES)
        classifier.classify_batch(batch.requirements)
        console.print(f"  ✓ Classification complete")
        
        # Step 3: Load personnel database
        progress.update(task, advance=20, description="[cyan]Loading personnel...")
        if personnel:
            personnel_db = PersonnelDatabase(personnel)
        else:
            personnel_db = PersonnelDatabase()  # Use default
        
        # Step 4: Generate emails
        progress.update(task, advance=20, description="[cyan]Generating emails...")
        generator = EmailGenerator()
        
        if group_by == 'area':
            emails = generator.generate_by_area(batch, personnel_db.lookup)
        else:
            emails = generator.generate_by_date(batch, personnel_db.lookup)
        
        console.print(f"  ✓ Generated {len(emails)} email drafts")
        
        # Step 5: Export to files
        progress.update(task, advance=20, description="[cyan]Exporting...")
        for email in emails:
            generator.export_to_file(email, output, format)
        
        console.print(f"  ✓ Exported to {output}")
    
    # Show summary
    _show_summary(batch, emails)

