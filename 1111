## CALCULATED FIELDS
```tableau
// Days to Due
DATEDIFF('day', TODAY(), [Due Date])

// Days Overdue
IF [Due Date] < TODAY() AND [Status] != 'COMPLETED' 
THEN DATEDIFF('day', [Due Date], TODAY())
ELSE 0
END

// Status Color
CASE [Status]
    WHEN 'COMPLETED' THEN 'Green'
    WHEN 'IN_PROGRESS' THEN 'Yellow'
    WHEN 'PENDING' THEN IF [Days to Due] < 3 THEN 'Orange' ELSE 'Blue' END
    WHEN 'OVERDUE' THEN 'Red'
END

// Urgency Score
CASE 
    WHEN [Status] = 'OVERDUE' THEN 100 + [Days Overdue]
    WHEN [Days to Due] <= 0 THEN 90
    WHEN [Days to Due] <= 3 THEN 70
    WHEN [Days to Due] <= 7 THEN 50
