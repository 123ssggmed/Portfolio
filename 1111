        '''
        Get balance sheet items for a specific date.
        '''
        result = {}
        for fact in self.facts:
            if fact.instant == as_of_date and fact.numeric_value is not None:
                result[fact.concept] = fact.numeric_value
        return result
    
    def get_income_statement_facts(self, start_date: date, 
                                   end_date: date) -> Dict[str, float]:
        '''
        Get income statement items for a period.
        '''
        result = {}
        for fact in self.facts:
            if (fact.period_start == start_date and 
                fact.period_end == end_date and 
                fact.numeric_value is not None):
                result[fact.concept] = fact.numeric_value
        return result
    
    def to_dataframe(self) -> 'pd.DataFrame':
        '''Convert facts to pandas DataFrame.'''
        import pandas as pd
        
        records = []
        for fact in self.facts:
            records.append({
                'concept': fact.concept,
                'value': fact.numeric_value or fact.value,
                'unit': fact.unit,
                'instant': fact.instant,
                'period_start': fact.period_start,
                'period_end': fact.period_end,
                **{f'dim_{k}': v for k, v in fact.dimensions.items()}
            })
        
